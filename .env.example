NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── MPC ingest script (scripts/ingest-mpc-cards.ts) ──────────────────────────
# Required for the ingest job. Put them in .env.local, or — to keep the ingest
# target (e.g. prod) separate from the app's dev config — in an optional
# .env.ingest, which is layered on top of .env.local and wins on conflicts.
# .env.ingest is gitignored. Only define here the keys that differ from .env.local.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key
