{
	"name": "wizcard",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": ">=22.11.0",
		"npm": ">=11.0.0"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "r=0; tsc --noEmit || r=1; eslint || r=1; prettier --check . || r=1; exit $r",
		"check:fix": "r=0; eslint --fix || r=1; prettier --write . || r=1; exit $r",
		"sb": "supabase",
		"sb:start": "supabase start",
		"sb:stop": "supabase stop",
		"sb:restart": "supabase stop && supabase start",
		"sb:status": "supabase status",
		"sb:reset": "supabase db reset --local",
		"sb:migrate": "supabase migration up --local",
		"sb:verify": "tsx scripts/verify-schema.ts",
		"sb:studio": "xdg-open http://127.0.0.1:54323",
		"sb:mail": "xdg-open http://127.0.0.1:54324",
		"ingest": "NODE_ENV=production systemd-inhibit npx tsx scripts/ingest-mpc-cards.ts",
		"logo:generate": "tsx scripts/generate-logo.ts",
		"clean": "rm -rf node_modules .next",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,mts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@inkjs/ui": "^2.0.0",
		"@phosphor-icons/react": "^2.1.10",
		"@supabase/ssr": "^0.9.0",
		"@supabase/supabase-js": "^2.99.1",
		"ink": "^7.0.5",
		"ink-scroll-view": "^0.3.7",
		"jspdf": "^4.2.1",
		"next": "^16.2.9",
		"next-intl": "^4.13.2",
		"nodemailer": "^9.0.3",
		"p-limit": "^7.3.0",
		"posthog-js": "^1.402.3",
		"posthog-node": "^5.21.2",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"sharp": "^0.35.3",
		"sql.js": "^1.14.1",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@types/node": "^20",
		"@types/nodemailer": "^8.0.1",
		"@types/opentype.js": "^1.3.10",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/sql.js": "^1.4.11",
		"babel-plugin-react-compiler": "1.0.0",
		"dotenv": "^17.4.2",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-i18next": "^6.1.5",
		"eslint-plugin-sonarjs": "^4.0.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"opentype.js": "^2.0.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"supabase": "^2.78.1",
		"tsx": "^4.22.4",
		"typescript": "5.9.3"
	}
}
